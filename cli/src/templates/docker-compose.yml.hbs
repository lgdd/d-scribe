networks:
  dd-demo:
    driver: bridge

volumes:
{{#if (eq instrumentation "datadog")}}
  dd-agent-data:
{{/if}}
{{#each depSpecs}}
{{#each this.namedVolumes}}
  {{this}}:
{{/each}}
{{/each}}

services:
{{#if (eq instrumentation "datadog")}}
  datadog-agent:
    image: gcr.io/datadoghq/agent:7
    container_name: {{projectName}}-datadog-agent
    pid: host
    security_opt:
      - apparmor:unconfined
    cap_add:
      - SYS_ADMIN
      - SYS_RESOURCE
      - SYS_PTRACE
      - NET_ADMIN
      - NET_BROADCAST
      - NET_RAW
      - IPC_LOCK
      - CHOWN
    environment:
      - DD_API_KEY=${DD_API_KEY}
      - DD_SITE={{ddSite}}
      - DD_APM_ENABLED=true
      - DD_APM_NON_LOCAL_TRAFFIC=true
      - DD_LOGS_ENABLED=true
      - DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true
      - DD_PROCESS_AGENT_ENABLED=true
      - DD_DOGSTATSD_NON_LOCAL_TRAFFIC=true
{{#each envVarEntries}}
      - {{this.[0]}}={{this.[1]}}
{{/each}}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - dd-agent-data:/opt/datadog-agent/run
      - /proc/:/host/proc/:ro
      - /sys/fs/cgroup/:/host/sys/fs/cgroup:ro
      - /etc/passwd:/etc/passwd:ro
      - /etc/group:/etc/group:ro
      - /:/host/root:ro
      - /sys/kernel/debug:/sys/kernel/debug
      - /etc/os-release:/etc/os-release
    networks:
      - dd-demo
    healthcheck:
      test: ["CMD-SHELL", "agent health"]
      interval: 10s
      timeout: 5s
      retries: 3
{{else if (eq instrumentation "otel")}}
  otel-collector:
    image: otel/opentelemetry-collector-contrib:latest
    container_name: {{projectName}}-otel-collector
    command: ["--config=/etc/otel-collector-config.yaml"]
    environment:
      - DD_API_KEY=${DD_API_KEY}
      - DD_SITE={{ddSite}}
    volumes:
      - ./otel-collector-config.yaml:/etc/otel-collector-config.yaml:ro
    ports:
      - "4317:4317"
      - "4318:4318"
    networks:
      - dd-demo
{{/if}}

{{#each services}}
  {{this.name}}:
    build: ./services/{{this.name}}
    container_name: {{../projectName}}-{{this.name}}
    environment:
{{#if (eq ../instrumentation "datadog")}}
      - DD_SERVICE={{this.name}}
      - DD_ENV=${DD_ENV}
      - DD_VERSION=1.0.0
      - DD_AGENT_HOST=datadog-agent
      - DD_TRACE_PROPAGATION_STYLE=datadog,tracecontext
{{else}}
      - OTEL_SERVICE_NAME={{this.name}}
      - OTEL_RESOURCE_ATTRIBUTES=deployment.environment=${DD_ENV},service.version=1.0.0
      - OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
      - OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
{{/if}}
      - PORT={{this.port}}
{{#each ../serviceEnvVarEntries}}
      - {{this.[0]}}={{this.[1]}}
{{/each}}
{{#if @first}}
    ports:
      - "{{this.port}}:{{this.port}}"
{{/if}}
    depends_on:
{{#if (eq ../instrumentation "datadog")}}
      datadog-agent:
        condition: service_healthy
{{else}}
      otel-collector:
        condition: service_started
{{/if}}
    networks:
      - dd-demo
    labels:
      com.datadoghq.tags.service: {{this.name}}
      com.datadoghq.tags.env: ${DD_ENV}
      com.datadoghq.tags.version: "1.0.0"
      com.datadoghq.ad.logs: '[{"source":"{{this.language}}","service":"{{this.name}}"}]'

{{/each}}
{{#if frontend}}
  frontend:
    build: ./frontend
    container_name: {{projectName}}-frontend
    ports:
      - "3000:80"
    environment:
      - DD_ENV=${DD_ENV}
    depends_on:
      service-1:
        condition: service_started
    networks:
      - dd-demo

{{/if}}
{{#each depSpecs}}
  {{this.serviceName}}:
    image: {{this.image}}
    container_name: {{../projectName}}-{{this.serviceName}}
{{#if this.command}}
    command: {{this.command}}
{{/if}}
{{#if this.ports}}
    ports:
{{#each this.ports}}
      - "{{this}}"
{{/each}}
{{/if}}
{{#if this.environment}}
    environment:
{{#each this.environment}}
      - {{this}}
{{/each}}
{{/if}}
{{#if this.volumes}}
    volumes:
{{#each this.volumes}}
      - {{this}}
{{/each}}
{{/if}}
{{#if this.healthcheck}}
    healthcheck:
      test: {{{json this.healthcheck.test}}}
      interval: {{this.healthcheck.interval}}
      timeout: {{this.healthcheck.timeout}}
      retries: {{this.healthcheck.retries}}
{{/if}}
    networks:
      - dd-demo

{{/each}}
  traffic:
    build: ./traffic
    container_name: {{projectName}}-traffic
    command: locust --headless -f /home/locust/locustfile.py --host http://service-1:8080 -u 5 -r 1
    environment:
      - TARGET_HOST=http://service-1:8080
    depends_on:
{{#each services}}
      {{this.name}}:
        condition: service_started
{{/each}}
    networks:
      - dd-demo
