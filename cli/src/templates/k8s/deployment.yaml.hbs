apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{name}}
  namespace: {{namespace}}
  labels:
    app: {{name}}
    tags.datadoghq.com/env: "{{ddEnv}}"
    tags.datadoghq.com/service: "{{name}}"
    tags.datadoghq.com/version: "1.0.0"
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{name}}
  template:
    metadata:
      labels:
        app: {{name}}
        tags.datadoghq.com/env: "{{ddEnv}}"
        tags.datadoghq.com/service: "{{name}}"
        tags.datadoghq.com/version: "1.0.0"
      annotations:
        ad.datadoghq.com/{{name}}.logs: '[{"source":"{{logSource}}","service":"{{name}}"}]'
    spec:
      containers:
        - name: {{name}}
          image: {{image}}
          imagePullPolicy: Never
          ports:
            - containerPort: {{port}}
          env:
{{#if (eq instrumentation "otel")}}
            - name: OTEL_SERVICE_NAME
              value: "{{name}}"
            - name: OTEL_RESOURCE_ATTRIBUTES
              value: "deployment.environment={{ddEnv}},service.version=1.0.0"
            - name: DD_AGENT_HOST
              valueFrom:
                fieldRef:
                  fieldPath: status.hostIP
            - name: OTEL_EXPORTER_OTLP_ENDPOINT
              value: "http://$(DD_AGENT_HOST):4318"
            - name: OTEL_EXPORTER_OTLP_PROTOCOL
              value: "http/protobuf"
{{else}}
            - name: DD_SERVICE
              value: "{{name}}"
            - name: DD_ENV
              valueFrom:
                fieldRef:
                  fieldPath: metadata.labels['tags.datadoghq.com/env']
            - name: DD_VERSION
              value: "1.0.0"
            - name: DD_AGENT_HOST
              valueFrom:
                fieldRef:
                  fieldPath: status.hostIP
            - name: DD_TRACE_PROPAGATION_STYLE
              value: "datadog,tracecontext"
{{/if}}
            - name: PORT
              value: "{{port}}"
