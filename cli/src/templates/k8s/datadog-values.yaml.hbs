datadog:
  apiKeyExistingSecret: datadog-secret
  site: {{ddSite}}
  env:
    - name: DD_ENV
      value: "{{ddEnv}}"
  apm:
    portEnabled: true
    socketEnabled: true
  logs:
    enabled: true
    containerCollectAll: true
  processAgent:
    enabled: true
    processCollection: true
{{#if hasProfiler}}
  profiling:
    enabled: true
{{/if}}
{{#if hasDbm}}
  dbm:
    enabled: true
{{/if}}
{{#if hasNetworkMonitoring}}
  networkMonitoring:
    enabled: true
{{/if}}
{{#unless (eq instrumentation "datadog")}}
  otelCollector:
    enabled: true
  otlp:
    receiver:
      protocols:
        grpc:
          enabled: true
          endpoint: "0.0.0.0:4317"
        http:
          enabled: true
          endpoint: "0.0.0.0:4318"
{{/unless}}

clusterAgent:
  enabled: true
  admissionController:
    mutateUnlabelled: true
