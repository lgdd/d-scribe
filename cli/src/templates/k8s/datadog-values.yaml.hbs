datadog:
  apiKeyExistingSecret: datadog-secret
  site: {{ddSite}}
  clusterName: {{namespace}}
  kubelet:
    tlsVerify: false
  env:
    - name: DD_ENV
      value: "{{ddEnv}}"
  apm:
    portEnabled: true
    socketEnabled: true
  logs:
    enabled: true
    containerCollectAll: true
  processAgent:
    enabled: true
    processCollection: true
{{#if hasProfiler}}
  profiling:
    enabled: true
{{/if}}
{{#if hasDbm}}
  dbm:
    enabled: true
{{/if}}
{{#if hasNetworkMonitoring}}
  networkMonitoring:
    enabled: true
{{/if}}
{{#unless (eq instrumentation "datadog")}}
  otelCollector:
    enabled: true
{{/unless}}

clusterAgent:
  enabled: true
  admissionController:
    mutateUnlabelled: true
