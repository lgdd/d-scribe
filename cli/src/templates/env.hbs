# Datadog API credentials
DD_API_KEY=your_api_key_here
DD_APP_KEY=your_app_key_here
DD_SITE={{ddSite}}

# Unified Service Tagging
DD_ENV={{ddEnv}}

{{#if frontend}}
# RUM (Frontend)
DD_RUM_APPLICATION_ID=your_rum_app_id_here
DD_RUM_CLIENT_TOKEN=your_rum_client_token_here
{{/if}}
{{#unless (eq instrumentation "datadog")}}
# OTel environment (injected when instrumentation mode is "otel" or "ddot")
OTEL_SERVICE_NAME=
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=${DD_ENV}
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
{{/unless}}
