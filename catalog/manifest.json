{
  "version": "1.0.0",
  "features": {
    "dbm:postgresql": {
      "label": "Database Monitoring (PostgreSQL)",
      "requires_deps": ["db:postgresql"],
      "datadog_products": ["dbm"],
      "agent_config": "dbm-postgresql"
    },
    "security:code": {
      "label": "Code Security / IAST",
      "requires_deps": [],
      "datadog_products": ["code_security"],
      "agent_env": { "DD_IAST_ENABLED": "true" }
    },
    "apm:profiling": {
      "label": "Continuous Profiling",
      "requires_deps": [],
      "datadog_products": ["profiling"],
      "agent_env": { "DD_PROFILING_ENABLED": "true" }
    },
    "security:siem": {
      "label": "Cloud SIEM",
      "requires_deps": ["auth:keycloak"],
      "datadog_products": ["siem", "cloud_siem"]
    },
    "dbm:mysql": {
      "label": "Database Monitoring (MySQL)",
      "requires_deps": ["db:mysql"],
      "datadog_products": ["dbm"],
      "agent_config": "dbm-mysql"
    },
    "dbm:mongodb": {
      "label": "Database Monitoring (MongoDB)",
      "requires_deps": ["db:mongodb"],
      "datadog_products": ["dbm"],
      "agent_config": "dbm-mongodb"
    },
    "security:sast": {
      "label": "Static Analysis (SAST)",
      "requires_deps": [],
      "datadog_products": ["code_security"]
    },
    "security:app": {
      "label": "App & API Protection",
      "requires_deps": [],
      "datadog_products": ["asm", "application_security"],
      "service_env": { "DD_APPSEC_ENABLED": "true" }
    },
    "security:workload": {
      "label": "Workload Protection",
      "requires_deps": [],
      "datadog_products": ["cwpp", "workload_security"],
      "agent_env": {
        "DD_RUNTIME_SECURITY_CONFIG_ENABLED": "true",
        "DD_SYSTEM_PROBE_ENABLED": "true",
        "DD_COMPLIANCE_CONFIG_ENABLED": "true",
        "DD_COMPLIANCE_CONFIG_HOST_BENCHMARKS_ENABLED": "true",
        "DD_RUNTIME_SECURITY_CONFIG_REMOTE_CONFIGURATION_ENABLED": "true",
        "HOST_ROOT": "/host/root"
      }
    },
    "ai:llmobs": {
      "label": "LLM Observability",
      "requires_deps": [],
      "datadog_products": ["llm_observability"],
      "agent_env": { "DD_LLMOBS_ENABLED": "true", "DD_LLMOBS_AGENTLESS_ENABLED": "true" },
      "service_env": { "DD_LLMOBS_ENABLED": "true" },
      "supported_backends": ["java:spring", "java:quarkus", "python:flask", "python:django", "node:express"],
      "supported_frontends": ["react:vite", "angular:esbuild", "vue:vite"]
    },
    "djm:spark": {
      "label": "Data Jobs Monitoring (Spark)",
      "requires_deps": ["compute:spark"],
      "datadog_products": ["data_jobs_monitoring"],
      "supported_backends": ["java:spring", "java:quarkus", "python:flask", "python:django"]
    },
    "djm:airflow": {
      "label": "Data Jobs Monitoring (Airflow)",
      "requires_deps": ["compute:airflow"],
      "datadog_products": ["data_jobs_monitoring"],
      "supported_backends": ["python:flask", "python:django"]
    },
    "dsm:kafka": {
      "label": "Data Streams Monitoring (Kafka)",
      "requires_deps": ["queue:kafka"],
      "datadog_products": ["data_streams_monitoring"],
      "agent_env": { "DD_DATA_STREAMS_ENABLED": "true" },
      "supported_backends": ["java:spring", "java:quarkus", "python:flask", "python:django", "node:express", "dotnet:aspnetcore", "go:gin"]
    },
    "delivery:feature-flags": {
      "label": "Feature Flags",
      "requires_deps": [],
      "datadog_products": ["feature_flags"],
      "agent_env": {
        "DD_REMOTE_CONFIG_ENABLED": "true",
        "DD_EXPERIMENTAL_FLAGGING_PROVIDER_ENABLED": "true",
        "DD_METRICS_OTEL_ENABLED": "true"
      },
      "supported_backends": [
        "java:spring", "java:quarkus",
        "python:flask", "python:django",
        "node:express",
        "ruby:rails",
        "dotnet:aspnetcore",
        "go:gin"
      ],
      "supported_frontends": ["react:vite", "angular:esbuild", "vue:vite"]
    }
  },
  "backends": {
    "java:spring": {
      "label": "Java Spring Boot",
      "path": "backends/java-spring"
    },
    "java:quarkus": {
      "label": "Java Quarkus",
      "path": "backends/java-quarkus"
    },
    "python:flask": {
      "label": "Python Flask",
      "path": "backends/python-flask"
    },
    "python:django": {
      "label": "Python Django",
      "path": "backends/python-django"
    },
    "node:express": {
      "label": "Node.js Express",
      "path": "backends/node-express"
    },
    "ruby:rails": {
      "label": "Ruby on Rails",
      "path": "backends/ruby-rails"
    },
    "php:laravel": {
      "label": "PHP Laravel",
      "path": "backends/php-laravel"
    },
    "dotnet:aspnetcore": {
      "label": ".NET ASP.NET Core",
      "path": "backends/dotnet-aspnetcore"
    },
    "go:gin": {
      "label": "Go Gin",
      "path": "backends/go-gin"
    }
  },
  "frontends": {
    "react:vite": {
      "label": "React (Vite)",
      "path": "frontends/react-vite"
    },
    "angular:esbuild": {
      "label": "Angular (esbuild)",
      "path": "frontends/angular-esbuild"
    },
    "vue:vite": {
      "label": "Vue (Vite)",
      "path": "frontends/vue-vite"
    }
  },
  "deps": {
    "db:postgresql": {
      "path": "deps/postgresql"
    },
    "cache:redis": {
      "path": "deps/redis"
    },
    "auth:keycloak": {
      "path": "deps/keycloak"
    },
    "db:mysql": {
      "path": "deps/mysql"
    },
    "db:mongodb": {
      "path": "deps/mongodb"
    },
    "queue:kafka": {
      "path": "deps/kafka"
    },
    "compute:spark": {
      "path": "deps/spark"
    },
    "compute:airflow": {
      "path": "deps/airflow"
    }
  },
  "infra": {
    "deploy": {
      "compose:local": { "label": "Docker Compose (local)" },
      "compose:aws:ec2": { "label": "Docker Compose on AWS EC2" },
      "k8s:local:minikube": { "label": "Kubernetes (local Minikube)" },
      "k8s:aws:ec2": { "label": "Kubernetes on AWS EC2 (Minikube)" },
      "k8s:aws:eks": { "label": "Kubernetes on AWS EKS", "status": "future" }
    },
    "defaults": {
      "compose": "compose:local",
      "compose:aws": "compose:aws:ec2",
      "k8s": "k8s:local:minikube",
      "k8s:local": "k8s:local:minikube",
      "k8s:aws": "k8s:aws:ec2"
    }
  }
}
