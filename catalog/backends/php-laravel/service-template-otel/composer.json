{
    "name": "example/service",
    "type": "project",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "open-telemetry/sdk": "^1.0",
        "open-telemetry/exporter-otlp": "^1.0",
        "open-telemetry/opentelemetry-auto-laravel": "^0.0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "open-telemetry/opentelemetry-auto-laravel": true
        }
    }
}
